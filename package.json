{
  "name": "onelink-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tokens:apply-stitch-theme": "node scripts/apply-onelink-stitch-theme-to-pen.mjs",
    "tokens:sync": "node scripts/sync-pen-tokens.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "bridge:codex": "node scripts/sync-claude-to-codex.mjs",
    "codex:stop-hook": "bash .codex/hooks/on-stop.sh",
    "codex:bridge-cli": "bash scripts/codex-with-claude-bridge.sh",
    "commit": "bash scripts/auto-commit.sh",
    "commit:dry": "bash scripts/auto-commit.sh --dry-run"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "better-sqlite3": "^12.6.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
