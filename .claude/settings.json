{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Write",
      "Bash(pnpm *)",
      "Bash(git *)"
    ],
    "deny": [
      "Write(.env*)",
      "Write(*.local.*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-commit.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "disabledMcpjsonServers": [
    "pencil"
  ]
}
